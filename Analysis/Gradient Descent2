import numpy as np

x = np.array([1,2,-3])

def f(x):
    return x[0] * np.log(x[0]) + x[1] ** 2 + x[2] ** 2

def dx(x):
    return np.log(x[0]) + 1
                  
def dy(x):
    return 2 * x[1]

def dz(x):
    return 2 * x[2]
                  
def grad(x):
    return np.array([dx(x), dy(x), dz(x)])
                
eps = 1e-4
                  
gamma = 0.02
f_old = f(x)
                  
x = x - grad(x) * gamma 
i = 1
f_new = f(x)
max_iter = 100
while abs(f_new - f_old) > eps and i < max_iter:
    print(f(x))
    f_old = f_new
    x = x - grad(x) * gamma                  
    f_new = f(x)
    i += 1                  
                  
result = x                  
print(result)  
print(f(result))                  

