import numpy as np

def f(w):
    x,y = w 
    return (x * np.log(x) + y)**2

def dfx(w):
    x,y = w
    return 2 * (x * np.log(x) + y) * (np.log(x) + 1)

def dfy(w):
    x,y = w
    return 2 * (x * np.log(x) + y) 

def grad(w):
    x,y = w 
    return np.array([dfx(w), dfy(w)])

w = np.array([0.25, 0.25])
gamma = 0.1
i = 1
max_iter = 1000

while f(w) > 0.000001 and i < max_iter:
    w = w - gamma * grad(w)
    i += 1 
    
result = w
print(result)
print(f(w))
