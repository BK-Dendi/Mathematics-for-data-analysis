import numpy as np

x = np.array([1.5, 1.5])

def f(x):
    return (
        (x[0] - 1) ** 2 * (x[1] + 1) ** 4
        + (x[0] + 1) ** 4 * (x[1] - 1) ** 2
        + (x[0] - 3) ** 2 * (x[1] - 2) ** 2
    )


def dx(x):
    return (
        2 * (x[0] - 1) * (x[1] + 1) ** 4
        + 4 * (x[0] + 1) ** 3 * (x[1] - 1) ** 2
        + 2 * (x[0] - 3) * (x[1] - 2) ** 2
    )


def dy(x):
    return (
        4 * (x[0] - 1) ** 2 * (x[1] + 1) ** 3
        + 2 * (x[0] + 1) ** 4 * (x[1] - 1)
        + 2 * (x[0] - 3) ** 2 * (x[1] - 2)
    )


print(f(x))
print([dx(x), dy(x)])
result = np.array([x[0] - dx(x),x[1] - dy(x)])
print(result) 
print(f(result))

