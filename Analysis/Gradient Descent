import numpy as np

x = np.array([1, 2])


gamma = 0.5


def f(x): 
	# f(x) = 0.5x^2 + 0.2y^2
	return 0.5*x[0]**2 + 0.2*x[1]**2 


def grad(x):
	# grad(x) = [x, 0.4y]
	dx = x[0]
	dy = 0.4 * x[1]
	return np.array([dx, dy])

print("Точка 0:", x)
print("f(x) =", f(x))
print()


x = x - grad(x) * gamma

print("Точка 1:", x)
print("f(x) =", f(x))


x = x - grad(x) * gamma

print("Точка 2:", x)
print("f(x) =", f(x))


x = x - grad(x) * gamma

print("Точка 3:", x)
print("f(x) =", f(x))

